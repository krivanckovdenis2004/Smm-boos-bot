import os
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import ApplicationBuilder, CommandHandler, CallbackQueryHandler, ContextTypes

TOKEN = os.getenv("BOT_TOKEN")

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    keyboard = [
        [InlineKeyboardButton("📈 Подписчики", callback_data="subs")],
        [InlineKeyboardButton("❤️ Лайки", callback_data="likes")],
        [InlineKeyboardButton("👁 Просмотры", callback_data="views")],
        [InlineKeyboardButton("💬 Комментарии", callback_data="comments")],
        [InlineKeyboardButton("📊 Статистика", callback_data="stats")],
    ]

    reply_markup = InlineKeyboardMarkup(keyboard)

    await update.message.reply_text(
        "🚀 SMM Boost — продвижение Instagram\n\n"
        "Выберите нужную услугу:",
        reply_markup=reply_markup
    )

async def buttons(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    texts = {
        "subs": "📈 Подписчики\n\nОтправьте ссылку на профиль Instagram.",
        "likes": "❤️ Лайки\n\nОтправьте ссылку на пост.",
        "views": "👁 Просмотры\n\nОтправьте ссылку на видео или Reels.",
        "comments": "💬 Комментарии\n\nОтправьте ссылку на пост и текст комментария.",
        "stats": "📊 Статистика\n\nОтправьте ссылку на профиль или пост.",
    }

    await query.message.reply_text(texts.get(query.data, "Выберите услугу из меню."))

def main():
    app = ApplicationBuilder().token(TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(buttons))

    app.run_polling()

if __name__ == "__main__":
    main()
